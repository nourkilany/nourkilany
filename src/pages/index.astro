---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg';
---

<Layout title="Nour Kilany">
  <main class="w-full min-h-screen flex flex-col items-center px-4 py-12">
    <!-- Spacer to push card toward center -->
    <div class="flex-1"></div>

    <!-- Profile Card -->
    <div class="w-full max-w-sm bg-zinc-900/80 backdrop-blur rounded-2xl border border-zinc-800 p-8 flex flex-col items-center gap-5 shadow-lg shadow-black/30">
      <Image
        src={profileImg}
        alt="Nour Kilany"
        width={224}
        height={224}
        loading="eager"
        class="w-28 h-28 rounded-full border-2 border-zinc-700 object-cover"
      />
      <div class="text-center">
        <h1 class="text-2xl font-bold text-zinc-100">Nour Kilany</h1>
        <p class="text-sm text-zinc-400 mt-1">Senior Software Developer</p>
      </div>
      <div class="flex gap-5 mt-1">
        <a
          href="https://x.com/_nkilany"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="text-zinc-400 hover:text-zinc-100 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/nour-kilany"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-zinc-400 hover:text-zinc-100 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a
          href="https://github.com/nourkilany"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-zinc-400 hover:text-zinc-100 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Experience — Claude Code Style -->
    <div class="w-full self-start">
      <div class="rounded-md border border-zinc-800 overflow-hidden shadow-lg shadow-black/30 bg-[#0c0c0c]">
        <!-- Session content -->
        <div class="px-5 py-5 font-mono text-xs leading-relaxed space-y-5">

          <!-- User message -->
          <div class="flex gap-3">
            <div class="text-amber-400 shrink-0 font-bold">❯</div>
            <div class="text-zinc-200">Show me your professional experience</div>
          </div>

          <!-- Claude response -->
          <div id="experience-list" class="space-y-4 pl-6 border-l border-zinc-800 ml-1">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
              <div>
                <span class="text-zinc-100 font-semibold">Senior Software Developer</span>
                <span class="text-zinc-600 mx-1.5">at</span>
                <span class="text-zinc-400">WellFit SA - SA (Remote)</span>
              </div>
              <span class="text-emerald-400/80 text-[11px] shrink-0">Mar 2025 — present</span>
            </div>

            <div class="h-px bg-zinc-800/50"></div>

            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
              <div>
                <span class="text-zinc-100 font-semibold">Senior Software Developer</span>
                <span class="text-zinc-600 mx-1.5">at</span>
                <span class="text-zinc-400">AuvoriaPrime - USA (Remote)</span>
              </div>
              <span class="text-emerald-400/80 text-[11px] shrink-0">Oct 2024 — present</span>
            </div>

            <div class="h-px bg-zinc-800/50"></div>

            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
              <div>
                <span class="text-zinc-100 font-semibold">Senior Software Developer</span>
                <span class="text-zinc-600 mx-1.5">at</span>
                <span class="text-zinc-400">EVA Pharma - EG (Hybrid)</span>
              </div>
              <span class="text-zinc-500 text-[11px] shrink-0">Oct 2023 — Oct 2024</span>
            </div>

            <!-- Hidden entries -->
            <div id="extra-experience" class="hidden space-y-4">
              <div class="h-px bg-zinc-800/50"></div>

              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                <div>
                  <span class="text-zinc-100 font-semibold">Software Developer</span>
                  <span class="text-zinc-600 mx-1.5">at</span>
                  <span class="text-zinc-400">AuvoriaPrime - USA (Remote)</span>
                </div>
                <span class="text-zinc-500 text-[11px] shrink-0">Mar 2021 — Oct 2023</span>
              </div>

              <div class="h-px bg-zinc-800/50"></div>

              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                <div>
                  <span class="text-zinc-100 font-semibold">Software Developer</span>
                  <span class="text-zinc-600 mx-1.5">at</span>
                  <span class="text-zinc-400">Orange Egypt - EG (Hybrid)</span>
                </div>
                <span class="text-zinc-500 text-[11px] shrink-0">Mar 2020 — Mar 2021</span>
              </div>

              <div class="h-px bg-zinc-800/50"></div>

              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                <div>
                  <span class="text-zinc-100 font-semibold">Backend Developer</span>
                  <span class="text-zinc-600 mx-1.5">at</span>
                  <span class="text-zinc-400">Ibtikar Technologies (Squadio) - EG (On-site)</span>
                </div>
                <span class="text-zinc-500 text-[11px] shrink-0">Aug 2019 — Mar 2020</span>
              </div>
            </div>

            <!-- Toggle hint -->
            <div id="expand-hint" class="pt-1">
              <button id="expand-btn" class="text-zinc-500 text-[11px] hover:text-zinc-300 transition-colors cursor-pointer">
                +3 more <span class="text-zinc-600">·</span> <span class="text-zinc-600">press</span> <kbd class="text-zinc-400 bg-zinc-800 px-1 py-0.5 rounded text-[10px]">Ctrl</kbd> <span class="text-zinc-600">+</span> <kbd class="text-zinc-400 bg-zinc-800 px-1 py-0.5 rounded text-[10px]">O</kbd> <span class="text-zinc-600">to expand</span>
              </button>
            </div>
          </div>

          <script>
            const extra = document.getElementById('extra-experience')!;
            const hint = document.getElementById('expand-hint')!;
            let expanded = false;

            function toggle() {
              expanded = !expanded;
              extra.classList.toggle('hidden');
              if (expanded) {
                hint.innerHTML = '<button id="expand-btn" class="text-zinc-500 text-[11px] hover:text-zinc-300 transition-colors cursor-pointer"><span class="text-zinc-600">press</span> <kbd class="text-zinc-400 bg-zinc-800 px-1 py-0.5 rounded text-[10px]">Ctrl</kbd> <span class="text-zinc-600">+</span> <kbd class="text-zinc-400 bg-zinc-800 px-1 py-0.5 rounded text-[10px]">O</kbd> <span class="text-zinc-600">to collapse</span></button>';
              } else {
                hint.innerHTML = '<button id="expand-btn" class="text-zinc-500 text-[11px] hover:text-zinc-300 transition-colors cursor-pointer">+3 more <span class="text-zinc-600">·</span> <span class="text-zinc-600">press</span> <kbd class="text-zinc-400 bg-zinc-800 px-1 py-0.5 rounded text-[10px]">Ctrl</kbd> <span class="text-zinc-600">+</span> <kbd class="text-zinc-400 bg-zinc-800 px-1 py-0.5 rounded text-[10px]">O</kbd> <span class="text-zinc-600">to expand</span></button>';
              }
              hint.querySelector('button')!.addEventListener('click', toggle);
            }

            hint.querySelector('button')!.addEventListener('click', toggle);

            document.addEventListener('keydown', (e) => {
              if (e.ctrlKey && e.key === 'o') {
                e.preventDefault();
                toggle();
              }
            });
          </script>

        </div>

        <!-- Input prompt with blinking cursor — bordered like Claude Code -->
        <div class="border-t border-b border-zinc-800 px-5 py-3">
          <div class="flex gap-3 items-center font-mono text-xs">
            <div class="text-amber-400 shrink-0 font-bold">❯</div>
            <span class="w-[7px] h-[18px] bg-zinc-500 animate-pulse"></span>
          </div>
        </div>

        <!-- Status line — mimics Claude Code bottom bar -->
        <div class="bg-zinc-900/80 border-t border-zinc-800 px-4 py-1.5 sm:py-1 flex items-center font-mono text-[10px]">
          <span class="text-emerald-400 flex items-center gap-1">
            <svg class="w-2.5 h-2.5" viewBox="0 0 8 8" fill="currentColor"><circle cx="4" cy="4" r="4"/></svg>
            nour-kilany
          </span>
          <span class="text-zinc-600 mx-2">|</span>
          <span class="text-zinc-500">years: <span class="text-zinc-300 font-semibold">6+</span></span>
          <span class="text-zinc-600 mx-2">|</span>
          <span class="text-zinc-500">PHP <span class="text-zinc-700">·</span> C#</span>
        </div>
        <!-- Plan mode bar -->
        <div class="bg-sky-900/30 border-t border-sky-800/40 px-4 py-1 flex items-center font-mono text-[10px]">
          <span class="text-sky-400 flex items-center gap-1.5">
            <svg class="w-2.5 h-2.5" viewBox="0 0 8 8" fill="currentColor"><circle cx="4" cy="4" r="4"/></svg>
            plan mode on
          </span>
          <span class="text-sky-700 mx-2">|</span>
          <span class="text-sky-500/70">building the next thing</span>
        </div>
      </div>
    </div>
  </main>
</Layout>
